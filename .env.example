# Mailgun (https://mailgun.com)
MAILGUN_API_KEY=key-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MAILGUN_DOMAIN=mg.ladnertraps.com

# Where quote inquiries are delivered
CONTACT_TO_EMAIL=sales@ladnertraps.com

# Optional — defaults to noreply@MAILGUN_DOMAIN
# CONTACT_FROM_EMAIL=Ladner Traps Website <noreply@mg.ladnertraps.com>

# reCAPTCHA v3 secret key (server-side only)
RECAPTCHA_SECRET_KEY=6Lexxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional — default is 0.5. Lower to 0.3 if legitimate users are blocked.
# RECAPTCHA_MIN_SCORE=0.5

# Temporary troubleshooting only — returns reCAPTCHA failure details in API response.
# Remove after the form is working.
# RECAPTCHA_DEBUG=true

# reCAPTCHA v3 site key goes in contact.html:
# <meta name="recaptcha-site-key" content="YOUR_SITE_KEY"/>
